<% profile = assistant_profile(@assistant) %>

<div
  class="chat"
  data-controller="chat"
  data-chat-storage-key-value="assistant:<%= @assistant.id %>:messages"
  data-chat-max-messages-value="10"
  data-chat-latest-question-value="<%= @question.to_s %>"
  data-chat-latest-answer-value="<%= @answer.to_s %>"
  data-chat-latest-sources-value="<%= json_escape(source_payload(@used_entries).to_json) %>"
  data-chat-sources-label-value="<%= profile[:sources_label] %>"
  data-chat-assistant-label-value="<%= profile[:answer_label] %>"
>
  <header class="hero">
    <div class="hero__nav">
      <div class="wordmark">
        <%= image_tag profile[:brand_mark], class: "wordmark__mark", alt: "" %>
        <span class="wordmark__copy">
          <span class="wordmark__name"><%= profile[:brand_name] %></span>
          <span class="wordmark__descriptor"><%= profile[:badge_label] %></span>
        </span>
      </div>
      <div class="hero__actions">
        <button type="button" class="new-chat" data-chat-target="clearButton" data-action="chat#clear">
          <%= profile[:new_chat_label] %>
        </button>
      </div>
    </div>

    <h1 class="hero__title"><%= profile[:hero_title] %></h1>

    <p class="hero__lede"><%= profile[:hero_lede] %></p>

    <%= form_with url: ask_assistant_path(@assistant), method: :post, data: { turbo: false }, class: "ask" do |f| %>
      <%= f.hidden_field :conversation_history, data: { chat_target: "history" } %>
      <%= f.text_field :question, value: nil, placeholder: profile[:input_placeholder], class: "ask__input", autocomplete: "off", data: { chat_target: "input" } %>
      <%= f.submit profile[:submit_label], class: "ask__button" %>
    <% end %>

    <% if profile[:suggested_questions].present? %>
      <div class="suggestions" aria-label="Suggested questions">
        <% profile[:suggested_questions].each do |question| %>
          <% icon, label = question.split(" ", 2) %>
          <button type="button" class="suggestion" data-action="chat#chooseSuggestion" data-question="<%= label || question %>">
            <span class="suggestion__icon" aria-hidden="true"><%= icon %></span>
            <span class="suggestion__label"><%= label || question %></span>
          </button>
        <% end %>
      </div>
    <% end %>
  </header>

  <section class="thread" data-chat-target="thread" aria-live="polite"></section>

  <% if @answer.present? %>
    <section class="answer answer--latest" data-chat-target="latest">
      <span class="eyebrow eyebrow--brand"><%= profile[:answer_label] %></span>
      <p class="answer__text"><%= @answer %></p>

      <% if @used_entries.present? && @used_entries.any? %>
        <div class="sources">
          <span class="sources__label"><%= profile[:sources_label] %></span>
          <ul class="sources__list">
            <% source_payload(@used_entries).each do |source| %>
              <li><%= source_button(source) %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </section>
  <% end %>

</div>

<% if profile[:footer_note].present? %>
  <p class="page-note"><%= profile[:footer_note] %></p>
<% end %>
