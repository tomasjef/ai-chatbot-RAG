<div class="chat">
  <h1>Support Assistant</h1>

  <%= form_with url: ask_path, method: :post, data: { turbo: false } do |f| %>
    <%= f.text_field :question, value: @question,
          placeholder: "Ask about shipping, returns, orders..." %>
    <%= f.submit "Ask" %>
  <% end %>

  <% if @answer.present? %>
    <div class="answer">
      <h2>Answer</h2>
      <p><%= @answer %></p>
    </div>

    <% if @used_entries.present? && @used_entries.any? %>
      <div class="sources">
        <h3>Sources used</h3>
        <ul>
          <% @used_entries.each do |entry| %>
            <li><%= entry.title %> <small>(<%= entry.category %>)</small></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
